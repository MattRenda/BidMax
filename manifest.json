{
  "manifest_version": 3,
  "name": "BidMax",
  "version": "2.0.0",
  "description": "AI-powered BidRL auction analyzer. Fetches all lots at once, ranks by profit, injects badges.",
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://www.bidrl.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bidrl.com/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html"
}
