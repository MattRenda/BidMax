# ─────────────────────────────────────────────────────────────
# BidMax monorepo — server/ (Node) + app/ (Expo / React Native)
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/

# Secrets / environment (keys resolved in-code or via Railway/EAS env)
.env
.env.*
!.env.example

# Expo / React Native — generated native projects, caches, build output.
# Native projects are regenerated by `expo prebuild` from app.json, so they
# are not committed (mirrors .easignore).
.expo/
dist/
web-build/
android/
ios/
expo-env.d.ts
*.tsbuildinfo

# Native signing material — must never be committed
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Editor / OS cruft
.DS_Store
Thumbs.db

# Claude Code — machine-local settings only
.claude/settings.local.json
